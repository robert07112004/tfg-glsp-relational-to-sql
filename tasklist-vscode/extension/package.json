{
  "name": "relational-vscode",
  "displayName": "Relational GLSP Diagram Editor",
  "version": "2.6.0",
  "private": "true",
  "description": "Extension for Relational GLSP diagrams",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "Eclipse-GLSP",
  "main": "dist/tasklist-extension.js",
  "files": [
    "lib",
    "server",
    "webview"
  ],
  "scripts": {
    "build": "tsc -b && yarn bundle",
    "bundle": "webpack",
    "bundle:prod": "webpack --config ./webpack.prod.js",
    "clean": "rimraf lib tsconfig.tsbuildinfo dist",
    "lint": "eslint --ext .ts,.tsx ./src",
    "package": "vsce package --yarn",
    "watch": "tsc -w",
    "watch:bundle": "webpack --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "relational.fit",
        "title": "Fit to Screen",
        "category": "Relational Diagram",
        "enablement": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "command": "relational.center",
        "title": "Center selection",
        "category": "Relational Diagram",
        "enablement": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "command": "relational.layout",
        "title": "Layout diagram",
        "category": "Relational Diagram",
        "enablement": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "command": "relational.exportAsSVG",
        "title": "Export as SVG",
        "category": "Relational Diagram",
        "enablement": "activeCustomEditorId == 'relational.glspDiagram'"
      }
    ],
    "customEditors": [
      {
        "viewType": "relational.glspDiagram",
        "displayName": "Relational Diagram Editor",
        "selector": [
          {
            "filenamePattern": "*.rmodel"
          }
        ]
      }
    ],
    "keybindings": [
      {
        "key": "alt+f",
        "command": "relational.fit",
        "when": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "key": "alt+c",
        "command": "relational.center",
        "when": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "key": "alt+l",
        "command": "relational.layout",
        "when": "activeCustomEditorId == 'relational.glspDiagram'"
      },
      {
        "key": "alt+e",
        "command": "relational.exportAsSVG",
        "when": "activeCustomEditorId == 'relational.glspDiagram'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "submenu": "relational.editor.title",
          "group": "bookmarks"
        }
      ],
      "relational.editor.title": [
        {
          "command": "relational.fit",
          "group": "navigation",
          "when": "activeCustomEditorId == 'relational.glspDiagram'"
        },
        {
          "command": "relational.center",
          "group": "navigation",
          "when": "activeCustomEditorId == 'relational.glspDiagram'"
        },
        {
          "command": "relational.layout",
          "group": "navigation",
          "when": "activeCustomEditorId == 'relational.glspDiagram'"
        },
        {
          "command": "relational.exportAsSVG",
          "when": "activeCustomEditorId == 'relational.glspDiagram'"
        }
      ]
    },
    "submenus": [
      {
        "id": "relational.editor.title",
        "label": "Relational Diagram"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "dependencies": {
    "@vscode/codicons": "^0.0.25"
  },
  "devDependencies": {
    "@eclipse-glsp/vscode-integration": "2.6.0",
    "@types/node": "20.x",
    "@types/vscode": "^1.54.0",
    "@vscode/vsce": "^2.24.0",
    "copy-webpack-plugin": "^11.0.0",
    "path": "^0.12.7",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^2.6.3",
    "ts-loader": "^6.2.1",
    "ts-node": "^9.1.1",
    "webpack-merge": "^5.9.0"
  },
  "engines": {
    "vscode": "^1.54.0"
  }
}